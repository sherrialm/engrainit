# ─────────────────────────────────────────────────────────────────────────────
# EngrainIt – Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase – Client (public, safe to expose) ────────────────────────────────
# These are read by the Firebase JS SDK in the browser.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Firebase Admin – Server-side only ─────────────────────────────────────────
# Used by API routes for server-side Firestore and Auth operations.
# Provide a full service account JSON object as a single-line string.
# Optional when running on Google Cloud with Application Default Credentials.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ── Gemini / Google AI – Server-side only ─────────────────────────────────────
# Required for AI loop generation, memory aid text, and daily briefings.
# Get a key from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key

# ── TTS – Text-to-Speech – Server-side only ───────────────────────────────────
# At least one TTS key is required for audio generation.
# ElevenLabs is the primary provider; Google Cloud TTS is the automatic fallback.

# Optional – Primary TTS provider (higher quality voices)
# Get a key from: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Optional – Fallback TTS provider (used if ElevenLabs is absent or fails)
# Requires Google Cloud Text-to-Speech API to be enabled on your project.
GOOGLE_CLOUD_TTS_API_KEY=your_google_cloud_tts_api_key

# ── Stripe – Server-side only ─────────────────────────────────────────────────
# Required when billing/subscriptions are active.
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe Price IDs for paid subscriptions (from your Stripe product catalog)
# Core tier
STRIPE_PRICE_CORE_MONTHLY=price_...
STRIPE_PRICE_CORE_YEARLY=price_...
# Pro tier
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Webhook secret for verifying Stripe event signatures
# Generate with: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional – Override the return URL after leaving the Stripe Customer Portal.
# Defaults to NEXT_PUBLIC_APP_URL/app.
# STRIPE_PORTAL_RETURN_URL=https://engrainit.com/app

# ── App / Feature Flags ───────────────────────────────────────────────────────
# The public URL of the deployed app (used for Stripe redirect URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional – Set to 'false' to disable new user sign-ups (e.g. during closed beta).
# Defaults to true (signups open) when not set.
# NEXT_PUBLIC_ALLOW_SIGNUPS=true

# ── Admin Utilities ───────────────────────────────────────────────────────────
# Secret required to call one-time admin API routes (e.g. billing backfill).
# Set to any strong random string. Never expose publicly.
# Generate with: openssl rand -hex 32
ADMIN_BACKFILL_SECRET=your_strong_random_secret_here

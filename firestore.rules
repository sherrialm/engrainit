rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — each user can only access their own data
    match /users/{userId} {

      // User's loops subcollection (Source: LoopService.ts)
      match /loops/{loopId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's profile subcollection (Source: tierStore.ts)
      match /profile/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's briefings subcollection (Source: BriefingService.ts)
      match /briefings/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's habits subcollection (Source: HabitService.ts)
      match /habits/{habitId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's sessions subcollection (Source: SessionService.ts)
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's settings subcollection (Source: UserPreferencesService.ts)
      match /settings/{docName} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's billing subcollection (Source: tierStore.ts, Stripe Webhook)
      // Allowed: Client READ (to check entitlement)
      // Restricted: No Client WRITE (managed via cloud functions/webhooks)
      match /billing/{document=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }
  }
}
